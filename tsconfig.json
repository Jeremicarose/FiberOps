{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "checkJs": false,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js",
    "public/**/*.js",
    "scripts/**/*.mjs",
    "tests/**/*.js"
  ]
}
