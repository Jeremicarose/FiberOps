# Primary Fiber RPC endpoint used by the browser app and CLI.
FIBER_RPC_URL=http://127.0.0.1:8227

# Optional secondary node for multi-node live comparisons.
FIBER_RPC_URL_NODE2=http://127.0.0.1:8237

# Optional explicit node-set override. Keep this JSON on one line if exported directly.
# FIBEROPS_NODE_SET_JSON=[{"id":"node1","name":"node1","endpoint":"http://127.0.0.1:8227","primary":true},{"id":"node2","name":"node2","endpoint":"http://127.0.0.1:8237","primary":false}]

# Optional history settings.
FIBEROPS_HISTORY_PATH=runtime/diagnostic-history.json
FIBEROPS_HISTORY_BACKEND=json-file

# Optional request-policy tuning.
FIBEROPS_MAX_JSON_BODY_BYTES=131072
FIBEROPS_ALLOW_EXTERNAL_LIVE_ENDPOINTS=false
FIBEROPS_ALLOW_INSECURE_TOKEN_FORWARDING=false
FIBEROPS_ROUTE_PROBE_ENABLED=true
